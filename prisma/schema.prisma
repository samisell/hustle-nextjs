generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("user") // "user" | "admin"
  referralCode String   @unique
  referredBy   String?  // referral code of the person who referred this user
  avatar       String?
  bio          String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  subscription     Subscription?
  wallet           Wallet?
  referrer         User?               @relation("Referrals", fields: [referredBy], references: [referralCode])
  referrals        User[]              @relation("Referrals")
  investments      UserInvestment[]
  enrollments      Enrollment[]
  notifications    Notification[]
  payments              Payment[]
  withdrawals           Withdrawal[]
  escrowContributions   EscrowContribution[]
  createdEscrows        EscrowTransaction[]  @relation("EscrowCreator")
  escrowDisputesRaised  EscrowDispute[]      @relation("DisputeRaiser")
  escrowDisputesResolved EscrowDispute[]     @relation("DisputeResolver")
  approvedMilestones    EscrowMilestone[]    @relation("MilestoneApprover")
  userAchievements      UserAchievement[]
  commissionsEarned     Commission[]           @relation("UserCommissions")
  commissionsGenerated  Commission[]           @relation("UserCommissionSource")
  payouts               Payout[]               @relation("UserPayouts")
  certifications        CourseCertification[]
  dealContributions     DealContribution[]
  dealVotes             DealVote[]
  dealPayouts           DealPayout[]
  createdDeals          InvestmentDeal[]     @relation("DealCreator")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  plan      String   @default("basic") // "basic" | "pro" | "premium"
  status    String   @default("inactive") // "active" | "inactive" | "expired"
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id                      String    @id @default(cuid())
  userId                  String
  amount                  Float
  currency                String    @default("USD")
  status                  String    @default("pending") // "pending" | "completed" | "failed"
  paymentMethod           String    @default("flutterwave") // "mock" | "flutterwave" | "card" | "bank"
  description             String?
  txRef                   String?   @unique // Flutterwave transaction reference
  flutterwaveTransactionId String?  // Flutterwave transaction ID from callback
  paymentType             String?   // "subscription" | "wallet_funding"
  metadata                String?   // JSON string for additional data (plan, etc.)
  paidAt                  DateTime? // when payment was confirmed
  createdAt               DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions Commission[]
}

model Course {
  id            String   @id @default(cuid())
  title         String
  description   String?
  category      String?
  thumbnail     String?
   difficulty    String   @default("beginner") // "beginner" | "intermediate" | "advanced"
  skillCategoryId String? // link to SkillCategory
  estimatedHours Int     @default(0) // estimated hours to complete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lessons        Lesson[]
  enrollments    Enrollment[]
  certifications CourseCertification[]
  skillCategory  SkillCategory?             @relation("CourseSkillCategory", fields: [skillCategoryId], references: [id])
}

model Lesson {
  id            String   @id @default(cuid())
  courseId      String
  title         String
  content       String   // text content
  order         Int      @default(0)
  estimatedMinutes Int    @default(0) // estimated reading time in minutes
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course     Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progresses LessonProgress[]
}

model Enrollment {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  progress       Float    @default(0) // percentage 0-100
  completedAt    DateTime? // when user reached 100%
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  earnings     Float    @default(0)
  status       String   @default("active") // "active" | "inactive"
  createdAt    DateTime @default(now())

  @@unique([referrerId, referredId])
}

model Earning {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  source      String   // "referral" | "investment" | "bonus"
  description String?
  createdAt   DateTime @default(now())

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  earnings     Earning[]
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String   // "credit" | "debit"
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  status        String   @default("pending") // "pending" | "approved" | "rejected" | "completed"
  walletAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvestmentOpportunity {
  id            String   @id @default(cuid())
  title         String
  description   String?
  minInvestment Float
  maxInvestment Float
  roiPercent    Float    // expected ROI percentage
  duration      String   // investment duration e.g. "30 days", "90 days"
  status        String   @default("active") // "active" | "closed" | "completed"
  totalPool     Float    @default(0) // total amount pooled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  investments UserInvestment[]
}

model UserInvestment {
  id            String   @id @default(cuid())
  userId        String
  opportunityId String
  amount        Float
  roiPercent    Float
  expectedReturn Float
  status        String   @default("active") // "active" | "completed" | "withdrawn"
  startDate     DateTime @default(now())
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity InvestmentOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // "info" | "success" | "warning" | "error"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ====================
// ESCROW SYSTEM MODELS
// ====================

model EscrowTransaction {
  id              String   @id @default(cuid())
  title           String
  description     String?
  type            String   @default("deal_funding") // "deal_funding" | "investment_deal" | "service_payment" | "milestone"
  status          String   @default("collecting") // "collecting" | "funded" | "active" | "disputed" | "partially_released" | "released" | "refunded" | "cancelled" | "expired"
  targetAmount    Float    // funding goal
  collectedAmount Float    @default(0) // current total collected
  currency        String   @default("USD")
  feePercent      Float    @default(0) // platform fee percentage
  minContribution Float    @default(1) // minimum contribution per user
  maxContribution Float    @default(0) // 0 = no max
  fundingDeadline DateTime? // deadline for reaching target
  releaseDate     DateTime? // scheduled auto-release date
  terms           String?  // escrow terms & conditions (JSON)
  createdBy       String   // admin user id who created the escrow
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contributions EscrowContribution[]
  milestones   EscrowMilestone[]
  disputes     EscrowDispute[]

  creator User @relation("EscrowCreator", fields: [createdBy], references: [id])
}

model EscrowContribution {
  id            String    @id @default(cuid())
  escrowId      String
  userId        String
  amount        Float
  paymentMethod String    @default("wallet") // "wallet" | "flutterwave" | "crypto"
  status        String    @default("pending") // "pending" | "confirmed" | "refunded"
  txRef         String?   @unique // payment transaction reference
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime  @default(now())

  escrow EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([escrowId, userId])
}

model EscrowMilestone {
  id           String    @id @default(cuid())
  escrowId     String
  title        String
  description  String?
  order        Int       @default(0)
  percentage   Float     // percentage of total funds to release (e.g., 50)
  status       String    @default("pending") // "pending" | "approved" | "released" | "rejected"
  approvedAt   DateTime?
  releasedAt   DateTime?
  approvedBy   String?   // admin user id
  releaseNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  escrow         EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  approvedByUser User?             @relation("MilestoneApprover", fields: [approvedBy], references: [id])
}

model EscrowDispute {
  id          String    @id @default(cuid())
  escrowId    String
  raisedById  String
  reason      String
  evidence    String?   // JSON string with evidence details
  status      String    @default("open") // "open" | "investigating" | "resolved" | "dismissed"
  resolution  String?
  resolvedBy  String?   // admin user id
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  escrow    EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  raisedBy  User              @relation("DisputeRaiser", fields: [raisedById], references: [id])
  resolver  User?             @relation("DisputeResolver", fields: [resolvedBy], references: [id])
}

// ====================
// ACHIEVEMENT SYSTEM
// ====================

model Achievement {
  id          String   @id @default(cuid())
  title       String
  description String?
  icon        String   @default("trophy") // icon name
  category    String   @default("general") // "learning" | "referral" | "investment" | "engagement" | "general"
  requirement String   // e.g. "Complete 5 courses", "Refer 10 users"
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  users UserAchievement[]
}

model UserAchievement {
  id            String     @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime   @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ====================
// MLM / PASSIVE INCOME SYSTEM
// ====================

model Commission {
  id              String   @id @default(cuid())
  userId          String   // the person who EARNS this commission
  sourceUserId    String   // the user whose action generated this commission
  paymentId       String?  // the payment that triggered this commission
  level           Int      // MLM level: 1=direct, 2=indirect, 3=extended
  amount          Float    // commission amount
  percentage      Float    // commission percentage applied
  status          String   @default("paid") // "paid" | "pending" | "reversed"
  description     String?
  createdAt       DateTime @default(now())

  user User @relation("UserCommissions", fields: [userId], references: [id], onDelete: Cascade)
  sourceUser User @relation("UserCommissionSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}

model Payout {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  method          String   // "bitcoin" | "usdt" | "bank_transfer"
  currency        String   @default("USD") // "USD" | "USDT" | "BTC"
  walletAddress   String?  // crypto wallet address
  bankName        String?  // bank name for bank transfer
  bankAccount     String?  // bank account number
  bankAccountName String?  // account holder name
  status          String   @default("pending") // "pending" | "processing" | "completed" | "failed" | "rejected"
  txHash          String?  // blockchain transaction hash for crypto payouts
  reference       String?  // bank transfer reference
  processedAt     DateTime?
  notes           String?  // admin notes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation("UserPayouts", fields: [userId], references: [id], onDelete: Cascade)
}

// ====================
// LEARNING HUB - SKILL CATEGORIES & CERTIFICATIONS
// ====================

model SkillCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String   @default("BookOpen") // lucide icon name
  color       String   @default("#D4AF37") // hex color for display
  order       Int      @default(0) // display order
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[] @relation("CourseSkillCategory")
}

model CourseCertification {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  badgeName      String   // display name e.g. "Crypto Trading Master"
  badgeIcon      String   @default("Award") // lucide icon name
  earnedAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ====================
// GROUP INVESTMENT POOL
// ====================

model InvestmentCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String   @default("TrendingUp") // lucide icon name
  color       String   @default("#D4AF37") // hex color for display
  image       String?  // URL to category image
  order       Int      @default(0) // display order
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals InvestmentDeal[]
}

model InvestmentDeal {
  id                String    @id @default(cuid())
  categoryId        String?
  title             String
  description       String
  longDescription   String?   // detailed markdown description
  location          String?   // e.g. "Lagos, Nigeria", "Dubai, UAE"
  minContribution   Float     @default(10)
  maxContribution   Float?    // null = no max
  targetAmount      Float     // total target pool
  currentPool       Float     @default(0)
  roiPercent        Float     // expected ROI percentage
  duration          String    // e.g. "6 months", "1 year"
  startDate         DateTime? // when deal becomes active
  maturityDate      DateTime? // when deal matures / ends
  votingDeadline    DateTime? // deadline for community voting
  votesFor          Int       @default(0)
  votesAgainst      Int       @default(0)
  status            String    @default("proposed") // "proposed" | "voting" | "funding" | "active" | "matured" | "completed" | "cancelled"
  imageUrl          String?
  riskLevel         String    @default("medium") // "low" | "medium" | "high"
  minVotes          Int       @default(10) // minimum votes needed to proceed
  approvalThreshold Float     @default(0.6) // 60% approval needed (0-1)
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category     InvestmentCategory? @relation(fields: [categoryId], references: [id])
  contributions DealContribution[]
  votes        DealVote[]
  payouts      DealPayout[]
  creator      User                  @relation("DealCreator", fields: [createdBy], references: [id])
}

model DealVote {
  id        String   @id @default(cuid())
  dealId    String
  userId    String
  vote      String   // "for" | "against"
  comment   String?
  createdAt DateTime @default(now())

  deal InvestmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
}

model DealContribution {
  id             String   @id @default(cuid())
  dealId         String
  userId         String
  amount         Float
  sharePercent   Float    @default(0) // percentage of total pool
  expectedReturn Float    @default(0)
  status         String   @default("confirmed") // "pending" | "confirmed" | "refunded"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deal InvestmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
}

model DealPayout {
  id          String    @id @default(cuid())
  dealId      String
  userId      String
  amount      Float     // total payout (principal + profit)
  principal   Float     // original contribution amount
  profit      Float     // earnings from the deal
  status      String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deal InvestmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}
